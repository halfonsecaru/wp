// Place your settings in this file to overwrite default and user settings.
{
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "files.exclude": {
    "out": false // set this to true to hide the "out" folder with the compiled JS files
  },
  "search.exclude": {
    "out": true // set this to false to include "out" folder in search results
  },
  // Turn off tsc task auto detection since we have the necessary tasks as npm scripts

  "editor.fontSize": 13,
  "screencastMode.fontSize": 50,
  "scm.inputFontSize": 13,
  "debug.console.fontSize": 13,
  "terminal.integrated.fontSize": 13,
  "chat.editor.fontSize": 13,
  "markdown.preview.fontSize": 13,
  "window.zoomLevel": 0.1,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "editor.inlineSuggest.showToolbar": "always",
  "git.ignoreLimitWarning": true,
  "editor.autoIndent": "full",

  // 🎨 Personalización de colores
  "workbench.colorCustomizations": {
    "tab.inactiveForeground": "#ffffff",
    "tab.unfocusedActiveForeground": "#ffffff",
    "tab.unfocusedInactiveForeground": "#ffffff",
    "tab.activeModifiedBorder": "#ffffff",
    "tab.inactiveModifiedBorder": "#ffffff",
    "activityBar.activeBackground": "#990000",
    "activityBar.background": "#990000",
    "activityBarBadge.background": "#000000",
    "activityBarBadge.foreground": "#e7e7e7",
    "sash.hoverBorder": "#990000",
    "statusBar.background": "#660000",
    "statusBarItem.hoverBackground": "#990000",
    "statusBarItem.remoteBackground": "#660000",
    "titleBar.activeBackground": "#660000",
    "titleBar.inactiveBackground": "#66000099",
    "tab.activeBackground": "#0f0c5a"
  },

  // 🎨 Integración opcional con Peacock
  "peacock.color": "#660000",
  "peacock.affectActivityBar": true,
  "peacock.affectStatusBar": true,
  "peacock.affectTitleBar": true,
  "peacock.affectTabActiveBorder": false,
  "peacock.keepForegroundColor": true,
  "peacock.surpriseMeOnStartup": false,
  "peacock.favoriteColors": [
    {
      "name": "Angular Red",
      "value": "#660000"
    },
    {
      "name": "NestJS Green",
      "value": "#1a4d1a"
    },
    {
      "name": "Default Purple",
      "value": "#8A2BE2"
    }
  ],
  "peacock.remoteColor": "#660000",
  "peacock.elementAdjustments": {
    "activityBar": "lighten",
    "statusBar": "none",
    "titleBar": "none"
  },

  // ⚙️ Otros

  "typescript.tsc.autoDetect": "on",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "workbench.settings.useSplitJSON": true,

  "workbench.iconTheme": "material-icon-theme",
  "editor.fontFamily": "Cascadia Code",

  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "prettier.requireConfig": false,
  "prettier.singleQuote": false,
  "prettier.semi": true,
  "prettier.useTabs": false,
  "prettier.tabWidth": 2,
  "prettier.trailingComma": "es5",
  "prettier.bracketSpacing": true,
  "prettier.arrowParens": "always",
  "editor.quickSuggestions": {
    "comments": "off",
    "strings": "off",
    "other": "off"
  },
  "angular.enable-strict-mode-prompt": false,
  "vsicons.presets.angular": true,
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  }
}
