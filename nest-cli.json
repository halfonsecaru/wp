{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "monorepo": false,
  "root": "apps",
  "sourceRoot": "apps",
  "projects": {
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.json"
      }
    },
    "nestjs": {
      "type": "library",
      "root": "libs/nestjs",
      "entryFile": "index",
      "sourceRoot": "libs/nestjs",
      "compilerOptions": {
        "tsConfigPath": "libs/nestjs/tsconfig.json"
      }
    }
  }
}