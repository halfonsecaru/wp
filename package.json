  "scripts": {
    "reload": "tsx scripts/reload.ts",
    "installSafe": "npx tsx scripts/install-node-modules.ts",
    "create": "npx tsx scripts/project-creator.ts",
    "installnode": "npx tsx ./scripts/install-node-modules.ts",
    "lint": "eslint src apps libs test --ext .ts --fix",
    "export:nest": "npx tsx ./scripts/nestjs/export-nest-project.ts",
    "dev:api": "npm run build:libs && cd apps/back/api && nest build && nest start --watch",
    "start:web": "ng serve --project=web",
    "dev:web": "npm run build:libs:watch && ng serve --project=web --configuration development -o",
    "build:web": "npm run build:libs && ng build --project=web --configuration production",
    "build:libs": "node scripts/build-libs.js",
    "build:libs:watch": "node scripts/build-libs.js --watch",
    "dev:demo": "ng serve --project=demo --configuration development",
    "start:demo": "ng serve --project=demo",
    "build:demo": "ng build --project=demo --configuration production",
    "test:alfbutton:button": "npx vitest run alfcomponents/components/alf-button/alf-button.spec.ts",
    "test:alfcomponents": "npx vitest run alfcomponents/",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "wp:down": "git pull origin main",
    "wp:up": "git add . && git commit -m \"wp: sync up\" && git push origin main"
  }
